{
  "name": "twitch-chat-viewer-bot",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "build": "npm run build:main && npm run build:ui",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "test": "jest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "chart.js": "^4.0.0",
    "dotenv": "^16.4.0",
    "electron": "^30.0.0",
    "ghost-cursor": "^1.4.2",
    "openai": "^4.104.0",
    "puppeteer": "^22.15.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "tmi.js": "1.8.5",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.9",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/tmi.js": "^1.8.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "electron-builder": "^24.13.0",
    "electron-playwright-helpers": "^2.1.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.twitch.chatviewerbot",
    "productName": "Twitch Chat Viewer Bot",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    }
  }
